# Copy to .env.local and fill in. NEVER commit real secrets.
NEXT_PUBLIC_SITE_URL=https://www.pushmanifesto.org

# Cloudflare API token for DNS ops (NOT used by the app). Scope: Zone > DNS > Edit.
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_EMAIL=        # only if using a Global API Key

# shadcn studio registry auth (used by the shadcn CLI for @ss-* registries).
# EMAIL=
# LICENSE_KEY=
