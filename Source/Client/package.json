{
  "name": "pushmanifesto",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "npm run clean",
    "prebuild": "npm run clean",
    "dev": "next dev -H 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "clean": "rimraf .next out coverage",
    "check-types": "tsc --noEmit --pretty",
    "format:write": "prettier --write \"src/**/*.{ts,tsx,mdx,css}\" --cache",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,mdx,css}\" --cache",
    "deploy:vercel": "npx vercel --prod"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.0",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.377.0",
    "next": "^15.5.9",
    "next-themes": "^0.4.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwind-merge": "^2.5.2"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.0",
    "@tailwindcss/typography": "^0.5.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "^15.5.9",
    "postcss": "^8",
    "prettier": "^3.3.2",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.3",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5"
  }
}
